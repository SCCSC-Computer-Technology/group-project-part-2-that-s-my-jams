@{
    ViewData["Title"] = "NBA Teams";
}

<script src="~/js/sportsApi.js"></script>

<div class="row mt-5">
    <div class="col-xs-12 col-md-3 team-list">
        <div class="mb-3">
            <input type="text" id="teamSearch" class="form-control" placeholder="Search teams (e.g. Lakers)..." autocomplete="off">
        </div>
        <ul class="list-group" id="teams">
        </ul>
    </div>

    <div class="col-xs-12 col-md-9">
        <ul class="nav nav-tabs" id="teamTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="info-tab" data-bs-toggle="tab" data-bs-target="#info-tab-pane" type="button" role="tab" aria-controls="info-tab-pane" aria-selected="true">Info</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#games-tab-pane" type="button" role="tab" aria-controls="games-tab-pane" aria-selected="false">Games</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#players-tab-pane" type="button" role="tab" aria-controls="players-tab-pane" aria-selected="false">Players</button>
            </li>
        </ul>

        <div class="tab-content" id="myTabContent">
            <div class="tab-pane fade show active" id="info-tab-pane" role="tabpanel" aria-labelledby="info-tab-pane" tabindex="0">
                <div class="row mt-4">
                    <div class="col">
                        <div class="card">
                            <div class="card-body" id="team-info-card">Select a Team</div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card">
                            <div class="card-body" id="standing-card">Select a Team</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="tab-pane fade mt-2 data-table" id="games-tab-pane" role="tabpanel" aria-labelledby="games-tab" tabindex="0">
                <table class="table table-striped table-hover table-bordered">
                    <thead>
                        <tr>
                            <th>Game Date</th>
                            <th>Teams</th>
                            <th>Final Score</th>
                        </tr>
                    </thead>
                    <tbody id="games-body">
                        <tr><td colspan="3" class="text-center text-muted"><em>Loading games...</em></td></tr>
                    </tbody>
                </table>
            </div>
            
            <div class="tab-pane fade mt-2 data-table" id="players-tab-pane" role="tabpanel" aria-labelledby="players-tab" tabindex="0">
                <table class="table table-striped table-hover table-bordered">
                    <thead>
                        <tr>
                            <th>Player Name</th>
                            <th>Position</th>
                            <th>Number</th>
                            <th>Ht / Wt</th>
                            <th>Experience</th>
                            <th>College</th>
                            <th>Key Stats</th>
                        </tr>
                    </thead>
                    <tbody id="players-body">
                        <tr>
                            <td colspan="7" class="text-center text-muted"><em>Loading roster data...</em></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    var teamList = document.getElementById('teams');
    var searchInput = document.getElementById('teamSearch');

    // Renders the sidebar list
    function renderTeams(filter = '') {
        var html = '';
        var filteredTeams = NBA_TEAM.filter(team =>
            team.name.toLowerCase().includes(filter.toLowerCase()) ||
            team.key.toLowerCase().includes(filter.toLowerCase())
        );

        for (var i = 0; i < filteredTeams.length; i++) {
            var team = filteredTeams[i];
            html += '<a href="#" class="list-group-item list-group-item-action" data-key="' + team.key + '">'
                  + '<img src="' + team.logo + '" class="img-thumbnail list-logo" />' + team.name + '</a>';
        }
        
        teamList.innerHTML = html || '<div class="list-group-item text-muted">No teams found</div>';
        attachLinkListeners();
    }

    // Click logic for sidebar
    function attachLinkListeners() {
        var links = teamList.querySelectorAll('a');
        links.forEach(link => {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                teamList.querySelectorAll('a').forEach(l => l.classList.remove('active'));
                this.classList.add('active');
                loadTeamDetail(this.getAttribute('data-key'));
            });
        });
    }

    // Search listener
    searchInput.addEventListener('input', function(e) {
        renderTeams(e.target.value);
    });

    // Main Data Loader
    async function loadTeamDetail(key) {
        var detail = await SportsApi.nba.getTeamDetail(key);
        if (!detail) return;

        // Info & Standings
        var team = detail.team;
        var s = detail.standing;
        
        document.getElementById('team-info-card').innerHTML =
            '<p><strong>' + (team.city || '') + ' ' + (team.name || '') + '</strong></p>'
          + '<p>Conference: ' + (team.conference || 'N/A') + '</p>'
          + '<p>Division: ' + (team.division || 'N/A') + '</p>'
          + (team.wikipediaLogoUrl ? '<img src="' + team.wikipediaLogoUrl + '" style="max-height:100px;" />' : '');

        document.getElementById('standing-card').innerHTML = s
            ? '<p><strong>Record:</strong> ' + s.wins + '-' + s.losses + '</p>'
            + '<p><strong>Win %:</strong> ' + (s.percentage * 100).toFixed(1) + '%</p>'
            : '<p>No standing data</p>';

        // Games Loop
        var gHtml = '';
        if (detail.games) {
            for (var i = 0; i < detail.games.length; i++) {
                var g = detail.games[i];
                var date = g.dateTime ? new Date(g.dateTime).toLocaleDateString() : 'TBD';
                var aScore = g.awayTeamScore ?? '-';
                var hScore = g.homeTeamScore ?? '-';
                gHtml += '<tr><td>' + date + '</td><td>' + g.awayTeam + ' @@ ' + g.homeTeam + '</td><td>' + aScore + ' - ' + hScore + '</td></tr>';
            }
        }
        document.getElementById('games-body').innerHTML = gHtml || '<tr><td colspan="3">No games</td></tr>';
        
        // Players Loop (With merged C# stats!)
        var pHtml = '';
        if (detail.players) {
            for (var i = 0; i < detail.players.length; i++) {
                var p = detail.players[i];
                var pts = p.points || 0;
                var reb = p.rebounds || 0;
                var ast = p.assists || 0;

                pHtml += '<tr>'
                       + '<td>' + (p.firstName + ' ' + p.lastName) + '</td>'
                       + '<td>' + (p.position || '-') + '</td>'
                       + '<td>#' + (p.jersey || '-') + '</td>'
                       + '<td>' + (p.height || '-') + ' / ' + (p.weight || '-') + '</td>'
                       + '<td>' + (p.experience || 'R') + '</td>'
                       + '<td>' + (p.college || '-') + '</td>'
                       + '<td><strong>' + pts + ' Pts, ' + reb + ' Reb, ' + ast + ' Ast</strong></td>'
                       + '</tr>';
            }
        }
        document.getElementById('players-body').innerHTML = pHtml || '<tr><td colspan="7">No players found</td></tr>';
    }

    // Run on load
    renderTeams();
    setTimeout(() => {
        var first = teamList.querySelector('a');
        if (first) first.click();
    }, 200);
</script>