@{
    ViewData["Title"] = "NFL Teams";
}

<script src="~/js/sportsApi.js"></script>

<div class="row mt-5">
    <div class="col-xs-12 col-md-3 team-list">
        <div class="mb-3">
            <input type="text" id="nflTeamSearch" class="form-control" placeholder="Search NFL teams (e.g. Chiefs)..." autocomplete="off">
        </div>
        <ul class="list-group" id="nflTeams">
        </ul>
    </div>

    <div class="col-xs-12 col-md-9">
        <ul class="nav nav-tabs" id="teamTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="info-tab" data-bs-toggle="tab" data-bs-target="#info-tab-pane" type="button" role="tab" aria-controls="info-tab-pane" aria-selected="true">Info</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#games-tab-pane" type="button" role="tab" aria-controls="games-tab-pane" aria-selected="false">Games</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#players-tab-pane" type="button" role="tab" aria-controls="players-tab-pane" aria-selected="false">Players</button>
            </li>
        </ul>

        <div class="tab-content" id="myTabContent">
            <div class="tab-pane fade show active" id="info-tab-pane" role="tabpanel" aria-labelledby="info-tab-pane" tabindex="0">
                <div class="row mt-4">
                    <div class="col">
                        <div class="card"><div class="card-body" id="team-info-card">Select a Team</div></div>
                    </div>
                    <div class="col">
                        <div class="card"><div class="card-body" id="standing-card">Select a Team</div></div>
                    </div>
                </div>
            </div>
            
            <div class="tab-pane fade mt-2 data-table" id="games-tab-pane" role="tabpanel" aria-labelledby="games-tab" tabindex="0">
                <table class="table table-striped table-hover table-bordered">
                    <thead>
                        <tr>
                            <th>Game Date</th>
                            <th>Teams</th>
                            <th>Final Score</th>
                        </tr>
                    </thead>
                    <tbody id="games-body">
                        <tr><td colspan="3" class="text-center text-muted"><em>Loading games...</em></td></tr>
                    </tbody>
                </table>
            </div>
            
            <div class="tab-pane fade mt-2 data-table" id="players-tab-pane" role="tabpanel" aria-labelledby="players-tab" tabindex="0">
                <table class="table table-striped table-hover table-bordered">
                    <thead>
                        <tr>
                            <th>Player Name</th>
                            <th>Position</th>
                            <th>Number</th>
                            <th>Ht / Wt</th>
                            <th>Experience</th>
                            <th>College</th>
                            <th>Key Stats</th>
                        </tr>
                    </thead>
                    <tbody id="players-body">
                        <tr><td colspan="7" class="text-center text-muted"><em>Loading roster data...</em></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    var nflTeamList = document.getElementById('nflTeams');
    var nflSearchInput = document.getElementById('nflTeamSearch');

    // Sidebar Logic: Filters and Renders the list
    function renderNFLTeams(filter = '') {
        var html = '';
        var filteredTeams = NFL_TEAM.filter(function(team) {
            return team.name.toLowerCase().includes(filter.toLowerCase()) ||
                   team.key.toLowerCase().includes(filter.toLowerCase());
        });

        for (var i = 0; i < filteredTeams.length; i++) {
            var team = filteredTeams[i];
            // Uses your original exact HTML string format
            html += '<a href="#" class="list-group-item list-group-item-action" data-key="' + team.key + '">'
                  + '<img src="' + team.logo + '" class="img-thumbnail list-logo" />' + team.name + '</a>';
        }
        
        nflTeamList.innerHTML = html || '<div class="list-group-item text-muted text-center">No teams found</div>';
        attachNFLLinkListeners();
    }

    // Click Logic: Handles selecting a team
    function attachNFLLinkListeners() {
        var links = nflTeamList.querySelectorAll('a');
        for (var i = 0; i < links.length; i++) {
            links[i].addEventListener('click', function (e) {
                e.preventDefault();
                var all = nflTeamList.querySelectorAll('a');
                for (var j = 0; j < all.length; j++) all[j].classList.remove('active');
                this.classList.add('active');
                loadTeamDetail(this.getAttribute('data-key'));
            });
        }
    }

    // Search Trigger: Updates as you type
    nflSearchInput.addEventListener('input', function(e) {
        renderNFLTeams(e.target.value);
    });

    // Main Data Loader: Fetches API data
    async function loadTeamDetail(key) {
        var detail = await SportsApi.nfl.getTeamDetail(key);
        if (!detail) return;

        var team = detail.team;
        var s = detail.standing;
        
        // Populate Info
        document.getElementById('team-info-card').innerHTML =
            '<p><strong>' + (team.city || '') + ' ' + (team.name || '') + '</strong></p>'
          + '<p>Conference: ' + (team.conference || 'N/A') + '</p>'
          + '<p>Division: ' + (team.division || 'N/A') + '</p>'
          + (team.wikipediaLogoUrl ? '<img src="' + team.wikipediaLogoUrl + '" style="max-height:100px;" />' : '');

        // Populate Standings
        document.getElementById('standing-card').innerHTML = s
            ? '<p><strong>Record:</strong> ' + s.wins + '-' + s.losses + '</p>'
            + '<p><strong>Win %:</strong> ' + (s.percentage * 100).toFixed(1) + '%</p>'
            + '<p><strong>Home:</strong> ' + s.homeWins + '-' + s.homeLosses + '</p>'
            + '<p><strong>Away:</strong> ' + s.awayWins + '-' + s.awayLosses + '</p>'
            : '<p>No standing data</p>';

        // Populate Games
        var gHtml = '';
        if (detail.games && detail.games.length > 0) {
            for (var i = 0; i < detail.games.length; i++) {
                var g = detail.games[i];
                var rawDate = g.date || g.dateTime || g.Day;
                var date = rawDate ? new Date(rawDate).toLocaleDateString() : 'TBD';
                var aScore = (g.awayScore !== null && g.awayScore !== undefined) ? g.awayScore : '-';
                var hScore = (g.homeScore !== null && g.homeScore !== undefined) ? g.homeScore : '-';

                gHtml += '<tr><td>' + date + '</td>'
                       + '<td>' + (g.awayTeam || '') + ' @@ ' + (g.homeTeam || '') + '</td>'
                       + '<td>' + aScore + ' - ' + hScore + '</td></tr>';
            }
        }
        document.getElementById('games-body').innerHTML = gHtml || '<tr><td colspan="3" class="text-center">No games</td></tr>';
        
        // Populate Players with Dynamic Stats
        var pHtml = '';
        if (detail.players && detail.players.length > 0) {
            for (var i = 0; i < detail.players.length; i++) {
                var p = detail.players[i];
                if (!p) continue;

                var pos = p.position || p.Position || '-';
                var statsString = '-';
                
                if (pos === 'QB') statsString = (p.passingYards || 0) + ' Pass Yds, ' + (p.passingTouchdowns || 0) + ' TD';
                else if (pos === 'RB') statsString = (p.rushingYards || 0) + ' Rush Yds, ' + (p.rushingTouchdowns || 0) + ' TD';
                else if (pos === 'WR' || pos === 'TE') statsString = (p.receptions || 0) + ' Rec, ' + (p.receivingYards || 0) + ' Yds';
                else if (['LB', 'CB', 'S', 'DB', 'DE', 'DT'].includes(pos)) statsString = (p.tackles || 0) + ' Tkls, ' + (p.sacks || 0) + ' Sacks';

                pHtml += '<tr>'
                       + '<td>' + (p.firstName || '') + ' ' + (p.lastName || 'Unknown') + '</td>'
                       + '<td>' + pos + '</td>'
                       + '<td>#' + (p.number || '-') + '</td>'
                       + '<td>' + (p.height || '-') + ' / ' + (p.weight || '-') + ' lbs</td>'
                       + '<td>' + (p.experience == 0 ? 'Rookie' : p.experience) + '</td>'
                       + '<td>' + (p.college || '-') + '</td>'
                       + '<td><strong>' + statsString + '</strong></td>'
                       + '</tr>';
            }
        }
        document.getElementById('players-body').innerHTML = pHtml || '<tr><td colspan="7" class="text-center">No player data available</td></tr>';
    }

    // Initial Load
    renderNFLTeams();
    setTimeout(function() {
        var first = nflTeamList.querySelector('a');
        if (first) first.click();
    }, 250);
</script>